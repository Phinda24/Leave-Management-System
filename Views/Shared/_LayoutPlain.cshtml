
@{
    Layout = null; // explicit: this is the root layout
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Leavify</title>

    <!-- Optional: keep Bootstrap and your site CSS for quick styling; remove if you want completely blank -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <!-- Added inline style to make the full-screen background light green -->
    <style>
        html, body {
            height: 100%;
        }

        /* light green page background */
        body {
            background-color: #e8f5e9; /* soft light green */
            min-height: 100vh;
        }

        /* keep cards visually separate on the green background */
        .card {
            background-color: #ffffff;
        }

        /* optional: give a little spacing from the edges */
        .page-container {
            padding: 1.5rem;
        }
    </style>
</head>

<body>
    <!-- Plain container where pages will render their content -->
    <div class="container py-4">
        @RenderBody()
    </div>

    <!-- Minimal scripts (remove if you want no JS) -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
