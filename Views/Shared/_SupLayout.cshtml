@using Microsoft.AspNetCore.Http
@using Leave_Management_system.viewModel
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Leavify</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    @RenderSection("Styles", required: false)

    <style>
        /* --- Page / background --- */
        html, body {
            height: 100%;
        }

        body {
            background-color: #e8f5e9; /* soft light green page background */
            min-height: 100vh;
            margin: 0;
        }

        /* --- Sidebar: fixed and full-height --- */
        #sidebar-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh; /* cover full viewport height */
            width: 260px; /* fixed width (adjust if you like) */
            overflow-y: auto; /* allow sidebar to scroll independently */
            background-color: #f1f9f3; /* subtle green panel - tweak as desired */
            z-index: 1030; /* above page content but below modals */
            padding: 1rem 0.75rem;
        }

            /* ensure inner list group stretches */
            #sidebar-wrapper .sidebar-nav {
                height: 100%;
                display: flex;
                flex-direction: column;
                gap: 0.25rem;
            }

            /* make the profile card full width inside sidebar */
            #sidebar-wrapper .profile-card {
                width: 100%;
            }

        /* --- Page content sits to the right of the fixed sidebar --- */
        #page-content-wrapper {
            margin-left: 260px; /* same as sidebar width */
            min-height: 100vh;
            overflow-y: auto; /* page content scrolls separately */
        }

        /* small padding for the app area */
        .app-container {
            padding-top: 1rem;
            padding-bottom: 3rem;
        }

        /* keep cards white for contrast on green background */
        .card {
            background-color: #ffffff;
        }

        /* --- Responsive: mobile behaviour (sidebar off-canvas) --- */
        @@media (max-width: 767.98px) {
            #sidebar-wrapper {
                transform: translateX(-100%);
                transition: transform 0.25s ease-in-out;
                width: 220px;
            }

                #sidebar-wrapper.open {
                    transform: translateX(0);
                }
            /* page content takes full width on small screens */
            #page-content-wrapper {
                margin-left: 0;
            }
            /* adjust navbar toggler so it controls sidebar on small screens */
            .navbar-toggler {
                z-index: 1100; /* above sidebar so it's clickable */
            }
        }
    </style>
</head>

<body class="@($"{ViewContext.RouteData.Values["controller"]}-{ViewContext.RouteData.Values["action"]}".ToLower())">

    <div id="wrapper" class="d-flex">
        <nav id="sidebar-wrapper" class="shadow-sm">

        <div class="profile">
            @{
                var pageVm = ViewData.Model as Leave_Management_system.viewModel.EmployeeHomeViewModel;
            }

            @if (pageVm != null && pageVm.Profile != null)
            {
                <div class="card profile-card mb-3 text-center p-3">
                    <img src="@(pageVm.Profile.PhotoUrl ?? Url.Content("~/images/default-avatar.png"))"
                         class="rounded-circle mb-2 profile-avatar"
                         style="width:90px;height:90px;" alt="Profile Photo" />
                    <h5 class="mb-0 profile-name">@pageVm.Profile.FullName</h5>
                    <p class="small mb-0 profile-email">@pageVm.Profile.Email</p>
                    <p class="small text-muted profile-phone">@pageVm.Profile.Phone</p>
                    <p class="small text-muted profile-dept">@pageVm.Profile.Department</p>
                </div>
            }
            else
            {

                try
                {
                    @await Component.InvokeAsync("Profile")
                }
                catch
                {
                    <div class="card profile-card mb-3 text-center p-3">
                        <img src="~/images/default-avatar.png" class="rounded-circle mb-2 profile-avatar" style="width:90px;height:90px;" alt="Profile Photo" />
                        <h5 class="mb-0 profile-name">Mr Vulandi</h5>
                        <p class="small mb-0 profile-email">thandoshaun2001@gmail.com</p>
                        <p class="small text-muted profile-phone">0606075274</p>
                        <p class="small text-muted profile-dept">—</p>
                    </div>
                }
            }
        </div>

        <!-- Sidebar (green panel) -->
        <div class="list-group list-group-flush sidebar-nav">
            <a class="list-group-item list-group-item-action d-flex align-items-center" asp-controller="SupHome" asp-action="SupDashboard">
                <i class="bi bi-grid-fill me-2"></i> Dashboard
            </a>

            <a class="list-group-item list-group-item-action d-flex align-items-center"
               asp-controller="LeaveRequest" asp-action="Pending">
                <i class="bi bi-plus-square me-2"></i> Leave Requests
            </a>

            @* <a class="list-group-item list-group-item-action d-flex align-items-center" asp-controller="LeaveRequest" asp-action="MyApplications" asp-route-employeeId="@HttpContextAccessor.HttpContext?.Session?.GetString("EmployeeId")">
                <i class="bi bi-journal-text me-2"></i> Reports
            </a> *@

                <a class="list-group-item list-group-item-action d-flex align-items-center @((ViewContext.RouteData.Values["controller"]?.ToString() ?? "").Equals("Reports", System.StringComparison.OrdinalIgnoreCase) ? "active" : "")"
                   asp-controller="Reports" asp-action="SupervisorReports">
                    <i class="bi bi-graph-up me-2"></i> Supervisor Reports
                </a>

               
        </nav>
        
        <!-- Page Content -->
        <div id="page-content-wrapper" class="flex-grow-1">
            <!-- Header -->
            <header>
                <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
                    <div class="container-fluid">
                        <a style="font-weight:700; color:#0b6b47;">Leavify</a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                            <div class="position-absolute top-0 end-0 d-flex align-items-center user-area">
                                <div class="user-name me-3">@HttpContextAccessor.HttpContext?.Session?.GetString("FullName") </div>
                                <form asp-controller="EmployeeAuth" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger ms-3 small">Logout</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </nav>
            </header>

            <!-- Hidden antiforgery token for FCM -->
            <form id="__af__form" style="display:none">
                @Html.AntiForgeryToken()
            </form>

            <!-- Body -->
            <div class="app-container container-fluid px-4">
                <main role="main" class="flex-grow-1">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <!-- Added inline style to make the full-screen background light green -->
    <style>
        html, body {
            height: 100%;
        }

        /* light green page background */
        body {
            background-color: #e8f5e9; /* soft light green */
            min-height: 100vh;
        }

        /* keep cards visually separate on the green background */
        .card {
            background-color: #ffffff;
        }

        /* optional: give a little spacing from the edges */
        .page-container {
            padding: 1.5rem;
        }
    </style>
    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Service Worker Registration -->
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/firebase-messaging-sw.js')
                .then(reg => console.log('Service Worker registered', reg.scope))
                .catch(err => console.warn('Service Worker registration failed', err));
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- FCM Registration Partial -->
    @await Html.PartialAsync("_FcmRegistration")
</body>
</html>