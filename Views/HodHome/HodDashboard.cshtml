@{
    ViewData["Title"] = "HOD Dashboard";
    Layout = "~/Views/Shared/_HodLayout.cshtml";
}


<!-- Simple full-screen calendar (pure client-side) -->
<div class="calendar-root">
    <header class="calendar-top">
        <div class="calendar-title">
            <button id="prevBtn" class="btn btn-sm btn-outline-secondary" aria-label="Previous month">&larr;</button>
            <div class="month-label" id="monthLabel">Month Year</div>
            <button id="nextBtn" class="btn btn-sm btn-outline-secondary" aria-label="Next month">&rarr;</button>
        </div>
        <div class="calendar-sub">Good day.</div>
    </header>

    <main class="calendar-main">
        <div class="weekdays">
            <div>Sun</div><div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div>
        </div>

        <div id="calendarGrid" class="calendar-grid" role="grid" aria-label="Month calendar"></div>
    </main>

    <footer class="calendar-footer">
        <div class="legend"><span class="dot green"></span> Today</div>
        <div class="legend"><span class="dot muted"></span> Other month</div>
    </footer>
</div>

<style>
    /* layout & palette */
    :root {
        --bg-1: #e8f5e9; /* page background */
        --panel: #ffffff; /* card/panel */
        --accent: #0b6b47; /* primary accent */
        --muted: #6b7a70;
    }

    html, body {
        height: 100%;
    }

    .calendar-root {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: linear-gradient(180deg, #f6fff9 0%, var(--bg-1) 100%);
        padding: 18px;
        box-sizing: border-box;
        gap: 12px;
    }

    .calendar-top {
        display: flex;
        flex-direction: column;
        gap: 6px;
        align-items: stretch;
    }

    .calendar-title {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        background: var(--panel);
        border-radius: 10px;
        padding: 12px 18px;
        box-shadow: 0 4px 12px rgba(6,20,10,0.04);
    }

    .month-label {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--accent);
        min-width: 200px;
        text-align: center;
    }

    .calendar-sub {
        color: var(--muted);
        font-size: 0.9rem;
        text-align: center;
    }

    .calendar-main {
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .weekdays {
        display: grid;
        grid-template-columns: repeat(7,1fr);
        gap: 6px;
        text-align: center;
        color: var(--muted);
        font-weight: 600;
        letter-spacing: 0.02em;
    }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        grid-auto-rows: 110px; /* day cell height */
        gap: 8px;
    }

    .day {
        background: linear-gradient(180deg,#ffffff,#fbfffc);
        border-radius: 10px;
        padding: 10px;
        box-shadow: 0 2px 8px rgba(6,20,10,0.04);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

        .day.other-month {
            opacity: 0.48;
            background: transparent;
            border: 1px dashed rgba(11,107,71,0.08);
        }

        .day .date-num {
            font-weight: 700;
            color: var(--accent);
            font-size: 1rem;
        }

        .day .small {
            color: var(--muted);
            font-size: 0.85rem;
            margin-top: 6px;
        }

        .day.today {
            outline: 3px solid rgba(11,107,71,0.12);
            box-shadow: 0 6px 18px rgba(11,107,71,0.06);
        }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
    }

        .dot.green {
            background: #0b6b47;
        }

        .dot.muted {
            background: #cfd6cf;
        }

    .calendar-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: var(--muted);
        font-size: 0.9rem;
    }

    /* small popup shown when user clicks a day */
    .day-popup {
        position: absolute;
        top: 10px;
        left: 10px;
        right: 10px;
        bottom: 10px;
        background: rgba(255,255,255,0.98);
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(6,20,10,0.12);
        padding: 8px;
        display: none;
        z-index: 40;
    }

        .day-popup.show {
            display: block;
        }

    /* responsive adjustments */
    @@media (max-width: 991.98px) {
        .calendar-grid {
            grid-auto-rows: 90px;
            gap: 6px;
        }

        .calendar-root {
            padding: 12px;
        }

        .month-label {
            font-size: 0.98rem;
            min-width: 150px;
        }
    }

    @@media (max-width: 575.98px) {
        .calendar-grid {
            grid-auto-rows: 80px;
        }

        .weekdays {
            font-size: 0.78rem;
        }
    }
</style>

<script>
    (function () {
        // Small client-side calendar with month navigation and a click popup.
        const monthLabel = document.getElementById('monthLabel');
        const grid = document.getElementById('calendarGrid');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');

        // track currently displayed month
        let view = new Date(); // starts on current date

        function startOfMonth(d) { return new Date(d.getFullYear(), d.getMonth(), 1); }
        function endOfMonth(d) { return new Date(d.getFullYear(), d.getMonth() + 1, 0); }

        function render() {
            grid.innerHTML = '';
            const first = startOfMonth(view);
            const last = endOfMonth(view);
            const startWeekday = first.getDay(); // 0 = Sun
            const daysInMonth = last.getDate();

            // Label
            monthLabel.textContent = view.toLocaleString(undefined, { month: 'long', year: 'numeric' });

            // we show the last few days of previous month at the start if needed
            const prevMonthLastDate = new Date(view.getFullYear(), view.getMonth(), 0).getDate();

            // total cells = 42 (6 rows)
            const totalCells = 42;
            for (let i = 0; i < totalCells; i++) {
                const cell = document.createElement('div');
                cell.className = 'day';
                // compute which date this cell should show
                const dayIndex = i - startWeekday + 1;
                let cellDate;
                let isOtherMonth = false;

                if (dayIndex <= 0) {
                    // previous month
                    isOtherMonth = true;
                    const dayNum = prevMonthLastDate + dayIndex;
                    const prevMonth = new Date(view.getFullYear(), view.getMonth() - 1, dayNum);
                    cellDate = prevMonth;
                } else if (dayIndex > daysInMonth) {
                    // next month
                    isOtherMonth = true;
                    const nextDay = dayIndex - daysInMonth;
                    const nextMonth = new Date(view.getFullYear(), view.getMonth() + 1, nextDay);
                    cellDate = nextMonth;
                } else {
                    // current month
                    const cur = new Date(view.getFullYear(), view.getMonth(), dayIndex);
                    cellDate = cur;
                }

                // build content
                const num = document.createElement('div');
                num.className = 'date-num';
                num.textContent = cellDate.getDate();
                cell.appendChild(num);

                // optional small placeholder area (no server data required)
                const small = document.createElement('div');
                small.className = 'small';
                small.textContent = cellDate.toLocaleDateString(undefined, { weekday: 'short' });
                cell.appendChild(small);

                // mark other-month days
                if (isOtherMonth) cell.classList.add('other-month');

                // mark today
                const today = new Date();
                if (cellDate.getFullYear() === today.getFullYear()
                    && cellDate.getMonth() === today.getMonth()
                    && cellDate.getDate() === today.getDate()) {
                    cell.classList.add('today');
                }

                // clickable: open a tiny popup for the day (client-side only)
                const popup = document.createElement('div');
                popup.className = 'day-popup';
                popup.innerHTML = '<div style="font-weight:700;margin-bottom:6px;">'
                    + cellDate.toLocaleDateString(undefined, { weekday: 'long', month: 'short', day: 'numeric', year: 'numeric' })
                    + '</div>'
                    + '<div class="text-muted" style="font-size:0.9rem;">This is a local-only popup — no server reads.</div>'
                    + '<div style="margin-top:10px;text-align:right;"><button class="btn btn-sm btn-outline-secondary close-popup">Close</button></div>';

                cell.appendChild(popup);

                cell.addEventListener('click', function (e) {
                    // toggle popup
                    const showing = popup.classList.contains('show');
                    // close other popups
                    document.querySelectorAll('.day-popup.show').forEach(p => p.classList.remove('show'));
                    if (!showing) popup.classList.add('show');
                    e.stopPropagation();
                });

                // close button inside popup
                popup.addEventListener('click', function (ev) {
                    if (ev.target && ev.target.classList.contains('close-popup')) {
                        popup.classList.remove('show');
                        ev.stopPropagation();
                    }
                });

                grid.appendChild(cell);
            }
        }

        // close popups when clicking outside
        document.addEventListener('click', function () {
            document.querySelectorAll('.day-popup.show').forEach(p => p.classList.remove('show'));
        });

        prevBtn.addEventListener('click', function (e) {
            view = new Date(view.getFullYear(), view.getMonth() - 1, 1);
            render();
            e.preventDefault();
        });

        nextBtn.addEventListener('click', function (e) {
            view = new Date(view.getFullYear(), view.getMonth() + 1, 1);
            render();
            e.preventDefault();
        });

        // init
        render();
    })();
</script>

